        "moment": "^2.29.1",
        "parallax-js": "^3.1.0",
        "prismjs": "^1.23.0",
        "react": "^17.0.1",
        "react-click-outside": "^3.0.1",
        "react-dom": "^17.0.1",
        "react-markdown": "^5.0.3",
        "react-router": "^5.2.0",
        "react-router-dom": "^5.2.0",
        "react-static": "^7.4.2",
        "react-static-plugin-react-router": "^7.4.2",
        "react-style-proptype": "^3.2.2",
        "remark-gfm": "^1.0.0",
