{
    "name": "documentation-platform",
    "version": "1.0.0",
    "description": "IOTA Documentation",
    "keywords": [
        "iota",
        "docs",
        "documentation"
    ],
    "license": "Apache-2.0",
    "scripts": {
        "build-projects": "node buildProjects",
